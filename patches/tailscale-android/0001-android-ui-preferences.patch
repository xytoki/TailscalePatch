+            responseHandler = { result ->
+              if (result.isFailure) {
+                Log.e(TAG, "Error saving IgnoreInterfaces: ${result.exceptionOrNull()}")
+                currentError.set(result.exceptionOrNull()?.localizedMessage)
+              } else {
+                Log.d(TAG, "IgnoreInterfaces set in backend.")
+                currentError.set(null)
+              }
+              onDone()
+            })
