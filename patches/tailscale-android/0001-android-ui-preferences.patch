+  fun toggleRouteLocal(onDone: () -> Unit) {
+    val newValue = !routeLocal.value
+    routeLocal.set(newValue)
+    val prefsOut = Ipn.MaskedPrefs()
+    prefsOut.RouteLocal = newValue
+    Log.d(TAG, "Will save RouteLocal in the backend: $newValue")
+    Client(viewModelScope)
+        .editPrefs(
+            prefsOut,
+            responseHandler = { result ->
+              if (result.isFailure) {
+                Log.e(TAG, "Error saving RouteLocal: ${result.exceptionOrNull()}")
+                currentError.set(result.exceptionOrNull()?.localizedMessage)
+              } else {
+                Log.d(TAG, "RouteLocal set in backend. New value: ${result.getOrNull()?.RouteLocal}")
+                currentError.set(null)
+              }
+              onDone()
+            })
+  }
+
+  fun saveIgnoreInterfaces(value: String, onDone: () -> Unit) {
+    ignoreInterfaces.set(value)
+    val prefsOut = Ipn.MaskedPrefs()
+    prefsOut.IgnoreInterfaces = value
+    Log.d(TAG, "Will save IgnoreInterfaces in the backend: $value")
+    Client(viewModelScope)
+        .editPrefs(
