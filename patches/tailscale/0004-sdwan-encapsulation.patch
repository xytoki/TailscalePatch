--- a/net/tstun/mtu.go
+++ b/net/tstun/mtu.go
@@ -106,6 +106,18 @@
 // - 16-byte authentication tag
 const wgHeaderLen = 40 + 8 + 4 + 4 + 8 + 16
 
+// DisguiseHeaderLen is the additional overhead added by the SD-WAN disguise
+// encapsulation layer on top of the WireGuard packet. When disguise mode is
+// active, each WireGuard UDP payload is wrapped with:
+//
+// - 8-byte SD-WAN protocol header (type, encrypt, sid, token)
+// - 20-byte fake inner IPv4 header
+// - 8-byte fake inner UDP header
+//
+// This makes the inner payload look like a tunneled IP+UDP flow to DPI
+// inspection. The total additional overhead is 36 bytes.
+const DisguiseHeaderLen = 8 + 20 + 8
+
 // TUNToWireMTU takes the MTU that the Tailscale TUN presents to the user and
 // returns the on-the-wire MTU necessary to transmit the largest packet that
 // will fit through the TUN, given that we have to add wireguard headers.
@@ -123,6 +135,27 @@ func WireToTUNMTU(w WireMTU) TUNMTU {
 	return TUNMTU(w - wgHeaderLen)
 }
 
+// TUNToWireMTUDisguised is like TUNToWireMTU but includes the additional
+// overhead from SD-WAN disguise encapsulation.
+func TUNToWireMTUDisguised(t TUNMTU) WireMTU {
+	return WireMTU(t + wgHeaderLen + DisguiseHeaderLen)
+}
+
+// WireToTUNMTUDisguised is like WireToTUNMTU but accounts for the additional
+// overhead from SD-WAN disguise encapsulation.
+func WireToTUNMTUDisguised(w WireMTU) TUNMTU {
+	if w < wgHeaderLen+DisguiseHeaderLen {
+		return 0
+	}
+	return TUNMTU(w - wgHeaderLen - DisguiseHeaderLen)
+}
+
+// SafeWireMTUDisguised returns the wire MTU that is safe to use when
+// SD-WAN disguise mode is active.
+func SafeWireMTUDisguised() WireMTU {
+	return TUNToWireMTUDisguised(safeTUNMTU)
+}
+
 // DefaultTUNMTU returns the MTU we use to set the Tailscale TUN
 // MTU. It is also the path MTU that we default to if we have no
 // information about the path to a peer.
@@ -148,6 +181,16 @@ func DefaultTUNMTU() TUNMTU {
 	return safeTUNMTU
 }
 
+// DefaultTUNMTUForDisguise returns the default TUN MTU when SD-WAN disguise
+// mode is active. It subtracts the disguise overhead from the standard safe MTU.
+func DefaultTUNMTUForDisguise() TUNMTU {
+	base := DefaultTUNMTU()
+	if base <= TUNMTU(DisguiseHeaderLen) {
+		return 0
+	}
+	return base - TUNMTU(DisguiseHeaderLen)
+}
+
 // SafeWireMTU returns the wire MTU that is safe to use if we have no
 // information about the path MTU to this peer.
 func SafeWireMTU() WireMTU {
