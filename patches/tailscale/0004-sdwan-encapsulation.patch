+func TestUpdateNodesRemovesDisguiseIndexOnPeerKeyRotation(t *testing.T) {
+	c := newConn(logger.Discard)
+	localPriv := key.NewNode()
+	setTestPrivateKey(c, localPriv)
+	peerPub1 := key.NewNode().Public()
+	peerPub2 := key.NewNode().Public()
+	for peerPub2 == peerPub1 {
+		peerPub2 = key.NewNode().Public()
+	}
+	selfNode := testNodeView(100, localPriv.Public(), key.DiscoPublic{}, "1.1.1.1/32")
+	peerNode1 := testNodeView(1, peerPub1, key.NewDisco().Public(), "2.2.2.2/32")
+	peerNode2 := testNodeView(1, peerPub2, key.NewDisco().Public(), "2.2.2.2/32")
+
+	c.updateNodes(selfNode, []tailcfg.NodeView{peerNode1})
+	oldSessionKey := sdwanSessionKey(deriveSDWANSession(localPriv.Public(), peerPub1))
+	c.updateNodes(selfNode, []tailcfg.NodeView{peerNode2})
+	newSessionKey := sdwanSessionKey(deriveSDWANSession(localPriv.Public(), peerPub2))
+
+	c.mu.Lock()
+	oldIndexed := append([]*endpoint(nil), c.sdwanPeersBySession[oldSessionKey]...)
+	newIndexed := append([]*endpoint(nil), c.sdwanPeersBySession[newSessionKey]...)
+	_, oldOk := c.peerMap.endpointForNodeKey(peerPub1)
+	_, newOk := c.peerMap.endpointForNodeKey(peerPub2)
+	c.mu.Unlock()
+	if oldOk {
+		t.Fatal("old peer key should have been removed")
+	}
+	if !newOk {
+		t.Fatal("new peer key should exist after rotation")
+	}
+	if len(oldIndexed) != 0 {
+		t.Fatalf("old disguise index retained after peer key rotation: %+v", oldIndexed)
+	}
+	if len(newIndexed) != 1 {
+		t.Fatalf("new disguise index not populated correctly: %+v", newIndexed)
+	}
+}
