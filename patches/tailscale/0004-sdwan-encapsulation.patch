+func TestSetFilterUpdatesDisguiseSendAndKeepsReceiveIndex(t *testing.T) {
+	c := newConn(logger.Discard)
+	localPriv := key.NewNode()
+	setTestPrivateKey(c, localPriv)
+	peerPub := key.NewNode().Public()
+	selfNode := testNodeView(100, localPriv.Public(), key.DiscoPublic{}, "1.1.1.1/32")
+	peerNode := testNodeView(1, peerPub, key.NewDisco().Public(), "2.2.2.2/32")
+	onRaw := mustSDWANCapRaw(t, sdwanModeOn)
+	offRaw := mustSDWANCapRaw(t, sdwanModeOff)
+	onFilter := testSDWANFilter(testSDWANMatch(selfNode, peerNode, onRaw))
+	offFilter := testSDWANFilter(testSDWANMatch(selfNode, peerNode, offRaw))
+
+	c.updateNodes(selfNode, []tailcfg.NodeView{peerNode})
+	c.SetFilter(onFilter)
+
+	wantSessionKey := sdwanSessionKey(deriveSDWANSession(localPriv.Public(), peerPub))
+	c.mu.Lock()
+	ep, ok := c.peerMap.endpointForNodeKey(peerPub)
+	indexed := append([]*endpoint(nil), c.sdwanPeersBySession[wantSessionKey]...)
+	c.mu.Unlock()
+	if !ok {
+		t.Fatal("peer endpoint not found")
+	}
+	if len(indexed) != 1 || indexed[0] != ep {
+		t.Fatalf("unexpected indexed endpoints: %+v", indexed)
+	}
+	if !testEndpointSendDisguised(ep) {
+		t.Fatal("sendDisguised was not enabled from filter capability")
+	}
+	if got := testEndpointSessionKey(ep); got != wantSessionKey {
+		t.Fatalf("cached disguise session = %+v, want %+v", got, wantSessionKey)
+	}
+
+	c.SetFilter(offFilter)
+	c.mu.Lock()
+	indexed = append([]*endpoint(nil), c.sdwanPeersBySession[wantSessionKey]...)
+	c.mu.Unlock()
+	if len(indexed) != 1 || indexed[0] != ep {
+		t.Fatalf("receive-side disguise index should remain populated: %+v", indexed)
+	}
+	if testEndpointSendDisguised(ep) {
+		t.Fatal("sendDisguised was not disabled by off rule")
+	}
+}
