+	c.mu.Unlock()
+	if !ok {
+		t.Fatal("peer endpoint not found after key rotation")
+	}
+	if len(oldIndexed) != 0 {
+		t.Fatalf("old disguise session index still populated: %+v", oldIndexed)
+	}
+	if len(newIndexed) != 1 || newIndexed[0] != ep {
+		t.Fatalf("new disguise session index incorrect: %+v", newIndexed)
+	}
+	if got := testEndpointSessionKey(ep); got != newSessionKey {
+		t.Fatalf("endpoint disguise session = %+v, want %+v", got, newSessionKey)
