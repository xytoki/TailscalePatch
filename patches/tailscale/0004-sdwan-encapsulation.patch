+func TestHandlePongConnLockedUsesDisguisedWireMTU(t *testing.T) {
+	c := newConn(logger.Discard)
+	localPriv := key.NewNode()
+	setTestPrivateKey(c, localPriv)
+	peerPub := key.NewNode().Public()
+	src := epAddr{ap: netip.MustParseAddrPort("1.2.3.4:5678")}
+	de := &endpoint{
+		c:             c,
+		publicKey:     peerPub,
+		sentPing:      map[stun.TxID]sentPing{},
+		endpointState: map[netip.AddrPort]*endpointState{src.ap: {}},
+		sendDisguised: true,
+	}
+	de.refreshDisguiseLocked(localPriv.Public())
+	txid := stun.NewTxID()
+	timer := time.NewTimer(time.Hour)
+	de.sentPing[txid] = sentPing{
+		to:        src,
+		at:        mono.Now(),
+		timer:     timer,
+		size:      pktLenToPingSize(1500, false, true),
+		disguised: true,
+	}
+	de.bestAddr = addrQuality{}
+
+	c.mu.Lock()
+	known := de.handlePongConnLocked(&disco.Pong{TxID: [12]byte(txid)}, nil, src)
+	c.mu.Unlock()
+	defer timer.Stop()
+	if !known {
+		t.Fatal("pong txid should have been recognized")
+	}
+	if de.bestAddr.wireMTU != 1500 {
+		t.Fatalf("bestAddr wireMTU = %v, want 1500", de.bestAddr.wireMTU)
+	}
+}
