+	peer := testNodeView(2, key.NodePublic{}, key.DiscoPublic{}, "2.2.2.2/32")
+	tests := []struct {
+		name string
+		filt *filter.Filter
+		want bool
+	}{
+		{
+			name: "absent",
+			filt: testSDWANFilter(),
+			want: false,
+		},
+		{
+			name: "bare-capability-enables",
+			filt: testSDWANFilter(testSDWANMatch(self, peer)),
+			want: true,
+		},
+		{
+			name: "mode-on-enables",
+			filt: testSDWANFilter(testSDWANMatch(self, peer, onRaw)),
+			want: true,
+		},
+		{
+			name: "mode-off-disables",
+			filt: testSDWANFilter(testSDWANMatch(self, peer, offRaw)),
+			want: false,
+		},
+		{
+			name: "off-overrides-on",
+			filt: testSDWANFilter(
+				testSDWANMatch(self, peer, onRaw),
+				testSDWANMatch(self, peer, offRaw),
+			),
+			want: false,
+		},
+	}
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			if got := nodeUsesSDWAN(nil, tt.filt, self, peer); got != tt.want {
+				t.Fatalf("nodeUsesSDWAN() = %v, want %v", got, tt.want)
+			}
+		})
+	}
+}
