+type sdwanSession struct {
+	sid     uint16
+	token   uint32
+	xorKey  [8]byte
+	srcIP   [4]byte
+	dstIP   [4]byte
+	srcPort uint16
+	dstPort uint16
+}
+
+func (s sdwanSession) valid() bool {
+	return s.sid != 0 || s.token != 0
+}
+
+type sdwanSessionIndexKey struct {
+	sid   uint16
+	token uint32
+}
+
+type sdwanCapabilityRule struct {
+	Mode string `json:"mode,omitempty"`
+}
+
+func sdwanSessionKey(session sdwanSession) sdwanSessionIndexKey {
+	return sdwanSessionIndexKey{sid: session.sid, token: session.token}
+}
+
+func nodeCaps(filt *filter.Filter, src, dst tailcfg.NodeView) tailcfg.PeerCapMap {
+	if filt == nil || !src.Valid() || !dst.Valid() {
+		return nil
+	}
+	for _, srcPrefix := range src.Addresses().All() {
+		if !srcPrefix.IsSingleIP() {
+			continue
+		}
+		srcAddr := srcPrefix.Addr()
+		for _, dstPrefix := range dst.Addresses().All() {
+			if !dstPrefix.IsSingleIP() {
+				continue
+			}
+			dstAddr := dstPrefix.Addr()
+			if dstAddr.BitLen() == srcAddr.BitLen() {
+				return filt.CapsWithValues(srcAddr, dstAddr)
+			}
+		}
+	}
+	return nil
+}
+
+func nodeUsesSDWAN(logf logger.Logf, filt *filter.Filter, src, dst tailcfg.NodeView) bool {
+	caps := nodeCaps(filt, src, dst)
+	if !caps.HasCapability(tailcfg.PeerCapabilitySDWANEncap) {
+		return false
+	}
+	rules, err := tailcfg.UnmarshalCapJSON[sdwanCapabilityRule](caps, tailcfg.PeerCapabilitySDWANEncap)
+	if err != nil {
+		if logf != nil {
+			logf("magicsock: invalid %q capability for %v->%v: %v", tailcfg.PeerCapabilitySDWANEncap, src.ID(), dst.ID(), err)
+		}
+		return false
+	}
+	if len(rules) == 0 {
+		return true
+	}
+	var enabled bool
+	for _, rule := range rules {
+		switch strings.ToLower(rule.Mode) {
+		case "", sdwanModeOn:
+			enabled = true
+		case sdwanModeOff:
+			return false
+		}
+	}
+	return enabled
+}
+
+func deriveSDWANSession(local, peer key.NodePublic) sdwanSession {
+	a, b := local, peer
+	if b.Less(a) {
+		a, b = b, a
+	}
+	seedInput := make([]byte, 0, 64)
+	seedInput = a.AppendTo(seedInput)
+	seedInput = b.AppendTo(seedInput)
+	seed := md5.Sum(seedInput)
+	username := hex.EncodeToString(seed[0:4])
+	password := hex.EncodeToString(seed[4:8])
+	xorInput := make([]byte, 0, len(username)+len(password))
+	xorInput = append(xorInput, username...)
+	xorInput = append(xorInput, password...)
+	xorSeed := md5.Sum(xorInput)
+	sid := binary.BigEndian.Uint16(seed[8:10])
+	if sid == 0 {
+		sid = 1
+	}
+	token := binary.BigEndian.Uint32(seed[10:14])
+	if token == 0 {
+		token = 1
+	}
+	return sdwanSession{
+		sid:     sid,
+		token:   token,
+		xorKey:  [8]byte(xorSeed[:8]),
+		srcIP:   [4]byte{10, seed[14], seed[15], 1},
+		dstIP:   [4]byte{10, seed[14], seed[15], 2},
+		srcPort: binary.BigEndian.Uint16(seed[0:2]) | 0xc000,
+		dstPort: binary.BigEndian.Uint16(seed[2:4]) | 0xc000,
+	}
+}
+
+func sdwanXOR(b []byte, key [8]byte) {
+	for i := range b {
+		b[i] ^= key[i%len(key)]
+	}
+}
+
+func ipv4HeaderChecksum(hdr []byte) uint16 {
+	var sum uint32
+	for i := 0; i < len(hdr); i += 2 {
+		if i == 10 {
+			continue
+		}
+		sum += uint32(binary.BigEndian.Uint16(hdr[i : i+2]))
+		for sum > 0xffff {
+			sum = (sum & 0xffff) + (sum >> 16)
+		}
+	}
+	return ^uint16(sum)
+}
+
+func (c *Conn) marshalSDWANPacket(peer key.NodePublic, wg []byte) []byte {
+	session := deriveSDWANSession(c.publicKeyAtomic.Load(), peer)
+	pkt := make([]byte, sdwanPayloadOffset+len(wg))
+	pkt[0] = sdwanPacketType
+	pkt[1] = sdwanEncryptFlag
+	binary.BigEndian.PutUint16(pkt[2:4], session.sid)
+	binary.BigEndian.PutUint32(pkt[4:8], session.token)
+	ipHdr := pkt[sdwanHeaderLen : sdwanHeaderLen+sdwanInnerIPv4Len]
+	udpHdr := pkt[sdwanHeaderLen+sdwanInnerIPv4Len : sdwanPayloadOffset]
+	ipHdr[0] = 0x45
+	binary.BigEndian.PutUint16(ipHdr[2:4], uint16(sdwanInnerIPv4Len+sdwanInnerUDPLen+len(wg)))
+	binary.BigEndian.PutUint16(ipHdr[4:6], session.sid)
+	binary.BigEndian.PutUint16(ipHdr[6:8], 0x4000)
+	ipHdr[8] = 64
+	ipHdr[9] = 17
+	copy(ipHdr[12:16], session.srcIP[:])
+	copy(ipHdr[16:20], session.dstIP[:])
+	binary.BigEndian.PutUint16(ipHdr[10:12], ipv4HeaderChecksum(ipHdr))
+	binary.BigEndian.PutUint16(udpHdr[0:2], session.srcPort)
+	binary.BigEndian.PutUint16(udpHdr[2:4], session.dstPort)
+	binary.BigEndian.PutUint16(udpHdr[4:6], uint16(sdwanInnerUDPLen+len(wg)))
+	copy(pkt[sdwanPayloadOffset:], wg)
+	sdwanXOR(pkt[sdwanHeaderLen:], session.xorKey)
+	return pkt
+}
+
+func (c *Conn) removeEndpointFromSDWANIndexLocked(ep *endpoint) {
+	if ep == nil {
+		return
+	}
+	ep.mu.Lock()
+	session := ep.disguiseSession
+	ep.mu.Unlock()
+	if !session.valid() {
+		return
+	}
+	k := sdwanSessionKey(session)
+	peers := c.sdwanPeersBySession[k]
+	for i, candidate := range peers {
+		if candidate == ep {
+			peers = append(peers[:i], peers[i+1:]...)
+			break
+		}
+	}
+	if len(peers) == 0 {
+		delete(c.sdwanPeersBySession, k)
+	} else {
+		c.sdwanPeersBySession[k] = peers
+	}
+}
+
+func (c *Conn) addEndpointToSDWANIndexLocked(ep *endpoint, session sdwanSession) {
+	if !session.valid() {
+		return
+	}
+	k := sdwanSessionKey(session)
+	c.sdwanPeersBySession[k] = append(c.sdwanPeersBySession[k], ep)
+}
+
+func (c *Conn) refreshEndpointDisguiseLocked(ep *endpoint) {
+	if ep == nil {
+		return
+	}
+	c.removeEndpointFromSDWANIndexLocked(ep)
+	ep.mu.Lock()
+	ep.refreshDisguiseLocked(c.publicKeyAtomic.Load())
+	session := ep.disguiseSession
+	ep.mu.Unlock()
+	c.addEndpointToSDWANIndexLocked(ep, session)
+}
+
+func (c *Conn) refreshAllEndpointDisguiseLocked() {
+	clear(c.sdwanPeersBySession)
+	c.peerMap.forEachEndpoint(func(ep *endpoint) {
+		ep.mu.Lock()
+		ep.refreshDisguiseLocked(c.publicKeyAtomic.Load())
+		session := ep.disguiseSession
+		ep.mu.Unlock()
+		c.addEndpointToSDWANIndexLocked(ep, session)
+	})
+}
+
+func (c *Conn) unwrapSDWANPacket(b []byte) (ep *endpoint, size int, ok bool) {
+	if len(b) < sdwanMinPacketLen || b[0] != sdwanPacketType || b[1] == 0 {
+		return nil, 0, false
+	}
+	selfKey := c.publicKeyAtomic.Load()
+	if selfKey.IsZero() {
+		return nil, 0, false
+	}
+	sid := binary.BigEndian.Uint16(b[2:4])
+	token := binary.BigEndian.Uint32(b[4:8])
+	c.mu.Lock()
+	candidates := append([]*endpoint(nil), c.sdwanPeersBySession[sdwanSessionIndexKey{sid: sid, token: token}]...)
+	c.mu.Unlock()
+	for _, candidate := range candidates {
+		candidate.mu.Lock()
+		session := candidate.disguiseSession
+		candidate.mu.Unlock()
+		if session.sid != sid || session.token != token {
+			continue
+		}
+		sdwanXOR(b[sdwanHeaderLen:], session.xorKey)
+		ipHdr := b[sdwanHeaderLen : sdwanHeaderLen+sdwanInnerIPv4Len]
+		if ipHdr[0] != 0x45 || ipHdr[9] != 17 ||
+			!bytes.Equal(ipHdr[12:16], session.srcIP[:]) ||
+			!bytes.Equal(ipHdr[16:20], session.dstIP[:]) {
+			sdwanXOR(b[sdwanHeaderLen:], session.xorKey)
+			continue
+		}
+		totalLen := int(binary.BigEndian.Uint16(ipHdr[2:4]))
+		if totalLen != len(b)-sdwanHeaderLen || totalLen < sdwanInnerIPv4Len+sdwanInnerUDPLen+1 {
+			sdwanXOR(b[sdwanHeaderLen:], session.xorKey)
+			continue
+		}
+		udpHdr := b[sdwanHeaderLen+sdwanInnerIPv4Len : sdwanPayloadOffset]
+		if binary.BigEndian.Uint16(udpHdr[0:2]) != session.srcPort || binary.BigEndian.Uint16(udpHdr[2:4]) != session.dstPort {
+			sdwanXOR(b[sdwanHeaderLen:], session.xorKey)
+			continue
+		}
+		udpLen := int(binary.BigEndian.Uint16(udpHdr[4:6]))
+		if udpLen != len(b)-sdwanHeaderLen-sdwanInnerIPv4Len || udpLen < sdwanInnerUDPLen+1 {
+			sdwanXOR(b[sdwanHeaderLen:], session.xorKey)
+			continue
+		}
+		size = copy(b, b[sdwanPayloadOffset:])
+		return candidate, size, true
+	}
+	return nil, 0, false
+}
